<?xml version="1.0" encoding="UTF-8" ?>
<Module>
<ModulePrefs title="RyGuys Math Vault - StealBrainrot" />
<Content type="html"><![CDATA[

<!DOCTYPE html>
<html lang="en-us">
<head>
<meta charset="utf-8"/>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/RyGuy1372/RyGuy1372.github.io@main/style.css"/>
<style>
    canvas:focus { outline: none; }
    html, body {
        padding: 0; margin: 0; overflow: hidden;
        -webkit-touch-callout: none; -webkit-user-select: none;
        -khtml-user-select: none; -moz-user-select: none;
        -ms-user-select: none; user-select: none;
        -webkit-tap-highlight-color: rgba(0,0,0,0);
        height: 100%;
        background-color: #000;
    }
    #unity-progress-bar-empty {
        width: 320px; height: 16px;
        background: rgba(255,255,255,0.18);
        border-radius: 999px; overflow: hidden;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.25);
    }
    #unity-progress-bar-full {
        height: 100%; border-radius: 999px;
        background: linear-gradient(90deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0.6) 50%, rgba(255,255,255,0.18) 100%),
            repeating-linear-gradient(45deg, rgba(255,255,255,0.35) 0px, rgba(255,255,255,0.35) 10px, rgba(255,255,255,0.12) 10px, rgba(255,255,255,0.12) 20px);
        background-size: 200% 100%, 40px 40px;
        animation: progressStripes 1.2s linear infinite;
    }
    #unity-progress-percent {
        margin-top: 8px; text-align: center;
        font-family: Arial, sans-serif; font-size: 16px;
        color: #fff; letter-spacing: 0.5px;
        text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    }
    @keyframes progressStripes {
        0% { background-position: 0% 0%, 0 0; }
        100% { background-position: 200% 0%, 40px 40px; }
    }
    .spinner {
        border: 5px solid rgba(255, 255, 255, 0.1);
        border-top: 5px solid #fff;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
        margin: 20px auto;
    }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>
</head>
<body class="dark">
<div id="unity-container" class="unity-desktop">
    <canvas id="unity-canvas" tabindex="-1"></canvas>
</div>
<div id="loading-cover" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; display: flex; align-items: center; justify-content: center; flex-direction: column;">
    <div id="unity-loading-bar">
        <div id="unity-logo"><img src="https://cdn.jsdelivr.net/gh/RyGuy1372/RyGuy1372.github.io@main/logo.png" style="max-width: 200px;"/></div>
        <div id="unity-progress-bar-empty" style="display: none;">
            <div id="unity-progress-bar-full"></div>
        </div>
        <div id="unity-progress-percent" style="display: none;">0%</div>
        <div class="spinner"></div>
    </div>
</div>

<script>
// LANGUAGE ENFORCEMENT
Object.defineProperty(navigator, "language", { get: function() { return "en"; } });
Object.defineProperty(navigator, "languages", { get: function() { return ["en"]; } });

// ASSET MAPPING - Now using jsDelivr
const baseRepo = "https://cdn.jsdelivr.net/gh/RyGuy1372/RyGuy1372.github.io@main";
const buildUrl = baseRepo + "/Build";
const loaderUrl = buildUrl + "/Build.loader.js";

// PART MERGER LOGIC
var splitFiles = { "Build.data.br": 6, "Build.wasm.br": 6 };
var mergedFileCache = {};

async function downloadAndMergeParts(fileName, partCount) {
    var parts = [], totalLoaded = 0;
    for (var i = 0; i < partCount; i++) {
        // Fetching parts through CDN
        var resp = await fetch(baseRepo + "/Build/parts/" + fileName + ".part" + i);
        if (!resp.ok) throw new Error("Fetch failed for " + fileName);
        var ab = await resp.arrayBuffer();
        parts.push(new Uint8Array(ab));
        totalLoaded += ab.byteLength;
    }
    var totalSize = parts.reduce((s,p) => s+p.length, 0);
    var merged = new Uint8Array(totalSize);
    var offset = 0;
    for (var j = 0; j < parts.length; j++) { merged.set(parts[j], offset); offset += parts[j].length; }
    return merged.buffer;
}

// FETCH INTERCEPTOR
var originalFetch = window.fetch.bind(window);
window.fetch = function(input, init) {
    var url = (typeof input === "string") ? input : (input && input.url ? input.url : "");
    for (var key in mergedFileCache) {
        if (url.indexOf(key) !== -1) {
            return Promise.resolve(new Response(mergedFileCache[key], {
                status:200, headers:{ "Content-Type":"application/octet-stream" }
            }));
        }
    }
    return originalFetch(input, init);
};

// UNITY INITIALIZATION
const config = {
    dataUrl: buildUrl + "/Build.data.br",
    frameworkUrl: buildUrl + "/Build.framework.js",
    codeUrl: buildUrl + "/Build.wasm.br",
    streamingAssetsUrl: "StreamingAssets",
    companyName: "DefaultCompany",
    productName: "StealBrainrot",
    productVersion: "0.1"
};

const canvas = document.querySelector("#unity-canvas");
const loadingCover = document.querySelector("#loading-cover");
const progressBarFull = document.querySelector("#unity-progress-bar-full");
const progressPercent = document.querySelector("#unity-progress-percent");

// Background image through jsDelivr
loadingCover.style.background = "url('" + baseRepo + "/background.png') center / cover";
loadingCover.style.display = "flex";

const script = document.createElement("script");
script.src = loaderUrl;
script.onload = async () => {
    try {
        mergedFileCache["Build.data.br"] = await downloadAndMergeParts("Build.data.br", 6);
        mergedFileCache["Build.wasm.br"] = await downloadAndMergeParts("Build.wasm.br", 6);
        
        createUnityInstance(canvas, config, (progress) => {
            document.querySelector(".spinner").style.display = "none";
            document.querySelector("#unity-progress-bar-empty").style.display = "block";
            progressBarFull.style.width = (100 * progress) + "%";
            progressPercent.style.display = "block";
            progressPercent.textContent = Math.round(progress * 100) + "%";
        }).then((unityInstance) => {
            loadingCover.style.display = "none";
        });
    } catch(err) { console.error("Load Error:", err); }
};
document.body.appendChild(script);

// FOCUS HANDLER
function FocusGame() { window.focus(); canvas.focus(); }
window.addEventListener('pointerdown', FocusGame);
</script>
</body>
</html>

]]>
</Content>
</Module>
